# ── Supabase ───────────────────────────────────────────────
# URL del proyecto y claves. La ANON/publishable es pública (RLS protege);
# la SERVICE_ROLE es secreta y solo se usa en el servidor.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Sitio ──────────────────────────────────────────────────
# URL pública del despliegue. La usan los QR para apuntar a /r/[slug].
NEXT_PUBLIC_SITE_URL=https://positivia.vercel.app

# ── Anthropic — features de IA, plan Pro (FASE 4) ──────────
# Claude Haiku: clasificación de urgencia, respuesta sugerida, resumen semanal.
ANTHROPIC_API_KEY=

# ── Twilio / WhatsApp — alertas al dueño (FASE 3) ──────────
# Si faltan, el sistema cae automáticamente a email (Resend).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ── Resend — email (FASE 3) ────────────────────────────────
RESEND_API_KEY=
# Remitente de los emails (opcional; por defecto alertas@positivia.app).
RESEND_FROM=

# ── Superadmin (FASE 6) ────────────────────────────────────
# Email que puede acceder al panel de gestión de clientes /superadmin.
SUPERADMIN_EMAIL=
